{
  "name": "sisearch",
  "displayName": "SI Search",
  "description": "Source Insight style search for VS Code",
  "version": "1.0.0",
  "publisher": "tianmeng9",
  "icon": "media/marketplace-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tianmeng9/vscode-sisearch.git"
  },
  "activationEvents": [
    "onView:siSearch.searchPanel",
    "onCommand:siSearch.syncIndex",
    "onCommand:siSearch.rebuildNative"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sisearch",
          "title": "SI Search",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sisearch": [
        {
          "type": "webview",
          "id": "siSearch.searchPanel",
          "name": "Search",
          "visibility": "visible"
        },
        {
          "id": "siSearch.highlightsView",
          "name": "Highlights",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "siSearch.focusSearchPanel",
        "title": "SI Search: Focus Search Panel"
      },
      {
        "command": "siSearch.toggleResultsPanel",
        "title": "SI Search: Toggle Results Panel"
      },
      {
        "command": "siSearch.nextResult",
        "title": "SI Search: Next Result"
      },
      {
        "command": "siSearch.previousResult",
        "title": "SI Search: Previous Result"
      },
      {
        "command": "siSearch.highlightSelection",
        "title": "SI Search: Highlight Selection"
      },
      {
        "command": "siSearch.clearAllHighlights",
        "title": "SI Search: Clear All Highlights",
        "icon": "$(clear-all)"
      },
      {
        "command": "siSearch.jumpToResult",
        "title": "SI Search: Jump to Result from Source"
      },
      {
        "command": "siSearch.clearResults",
        "title": "Clear Search Results",
        "icon": "$(clear-all)"
      },
      {
        "command": "siSearch.removeHighlight",
        "title": "Remove Highlight",
        "icon": "$(close)"
      },
      {
        "command": "siSearch.syncIndex",
        "title": "SI Search: Synchronize Files",
        "icon": "$(sync)"
      },
      {
        "command": "siSearch.clearIndex",
        "title": "SI Search: Clear Symbol Index"
      },
      {
        "command": "siSearch.rebuildNative",
        "title": "SI Search: Rebuild Native (SQLite)",
        "category": "SI Search"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "siSearch.syncIndex",
          "when": "view == siSearch.searchPanel",
          "group": "navigation@1"
        },
        {
          "command": "siSearch.clearResults",
          "when": "view == siSearch.searchPanel",
          "group": "navigation@2"
        },
        {
          "command": "siSearch.clearAllHighlights",
          "when": "view == siSearch.highlightsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "siSearch.removeHighlight",
          "when": "view == siSearch.highlightsView",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "siSearch.focusSearchPanel",
        "key": "ctrl+/",
        "mac": "cmd+/"
      },
      {
        "command": "siSearch.toggleResultsPanel",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/"
      },
      {
        "command": "siSearch.nextResult",
        "key": "ctrl+shift+f4",
        "mac": "cmd+shift+f4"
      },
      {
        "command": "siSearch.previousResult",
        "key": "ctrl+shift+f3",
        "mac": "cmd+shift+f3"
      },
      {
        "command": "siSearch.highlightSelection",
        "key": "ctrl+shift+f8",
        "mac": "cmd+shift+f8"
      },
      {
        "command": "siSearch.jumpToResult",
        "key": "alt+j",
        "when": "editorTextFocus"
      },
      {
        "command": "siSearch.syncIndex",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "configuration": {
      "title": "SI Search",
      "properties": {
        "siSearch.includeFileExtensions": {
          "type": "array",
          "default": [
            ".c",
            ".h",
            ".cpp",
            ".hpp",
            ".cc",
            ".cxx",
            ".hxx",
            ".inl"
          ],
          "description": "File extensions to include in search"
        },
        "siSearch.includePaths": {
          "type": "array",
          "default": [],
          "description": "Subdirectories to include in symbol indexing (e.g. [\"src/wifi\", \"src/drivers\"]). Empty means entire workspace."
        },
        "siSearch.excludePatterns": {
          "type": "array",
          "default": [
            "**/build/**",
            "**/.git/**",
            "**/node_modules/**"
          ],
          "description": "Glob patterns to exclude from search"
        },
        "siSearch.highlightColors": {
          "type": "array",
          "default": [
            "cyan",
            "pink",
            "lightgreen",
            "magenta",
            "cornflowerblue",
            "orange",
            "green",
            "red"
          ],
          "description": "Colors for manual highlight marking"
        },
        "siSearch.highlightBox": {
          "type": "boolean",
          "default": true,
          "description": "When true, highlights use border-only box style; when false, highlights use background fill"
        },
        "siSearch.navigationWrap": {
          "type": "boolean",
          "default": true,
          "description": "Wrap around when navigating past last/first result"
        },
        "siSearch.autoSyncOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync dirty files when saving"
        },
        "siSearch.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic sync after file changes"
        },
        "siSearch.autoSyncDelay": {
          "type": "number",
          "default": 5000,
          "description": "Debounce delay in milliseconds before auto sync triggers"
        },
        "siSearch.parser.maxFileSizeBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 0,
          "description": "Files larger than this byte count fall back to a fast regex-based symbol extractor instead of the full tree-sitter parser. Default is 1 MB (1048576). Set to 0 to disable the fallback and always use tree-sitter. WARNING: tree-sitter is compiled to WebAssembly and its linear memory is hard-capped at 2 GB by web-tree-sitter; parsing machine-generated files (for example Linux kernel driver headers like dcn_3_2_0_sh_mask.h at ~24 MB, or AMD GPU offset.h at 1-2 MB with 100k #define lines) can exhaust this ceiling and crash the VS Code extension host (exit 134 / SIGABRT). The default of 1 MB covers AMD GPU register headers too. Disabling the fallback (0) or setting this value very high (several MB) re-exposes you to that crash; only do so if you know your workspace has no such files."
        },
        "siSearch.search.duringSyncBehavior": {
          "type": "string",
          "enum": [
            "prompt-grep-fallback",
            "prompt-cancel",
            "grep-fallback",
            "cancel"
          ],
          "default": "prompt-grep-fallback",
          "description": "Behavior when a symbol search is issued while the index is currently being synchronized. prompt-grep-fallback (default): ask the user; choosing 'use text search' falls back to ripgrep. prompt-cancel: ask the user; choosing returns no results. grep-fallback: silently fall back to ripgrep. cancel: silently return empty results. Subsequent searches within 1 second reuse the user's last choice without re-prompting, so the dialog doesn't spam while the user types."
        },
        "siSearch.search.maxResults": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "maximum": 10000,
          "description": "Maximum number of results returned in a single query or loadMore batch. Additional results are fetched on demand as the user scrolls the results panel (virtual scrolling). Increasing this makes each scroll batch bigger but slower; 200 works well for both small and huge result sets."
        }
      }
    }
  },
  "scripts": {
    "copy-wasm": "node scripts/copy-wasm.js",
    "vscode:prepublish": "npm run copy-wasm && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js",
    "bench:sync": "node ./out/test/benchmark/syncBench.js",
    "rebuild": "npm rebuild better-sqlite3",
    "rebuild-electron": "electron-rebuild -v 39.8.3 -f -w better-sqlite3",
    "postinstall": "npm run rebuild-electron || echo 'electron-rebuild failed; run npm run rebuild-electron manually'",
    "package": "vsce package",
    "verify-sqlite": "node scripts/verify-sqlite.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.2.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "@vscode/ripgrep": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "shiki": "^4.0.2",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "web-tree-sitter": "^0.26.8"
  }
}
